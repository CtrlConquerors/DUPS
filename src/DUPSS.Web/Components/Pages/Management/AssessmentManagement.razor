@page "/Management/Assessment"
@using DUPSS.API.Models.DTOs
@using DUPSS.Web.Components.Layout
@using DUPSS.Web.Components.Service

@inject AssessmentApiService AssessmentService
@inject NavigationManager Navigation
@layout ManagementLayout

<PageTitle>Assessment Management</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Assessment Management</h2>
        <button class="btn btn-primary" @onclick="ShowCreateModal">
            <i class="fas fa-plus"></i> Create New Assessment
        </button>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var assessment in assessments)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">@assessment.Name</h5>
                            <span class="badge @(assessment.IsActive ? "bg-success" : "bg-secondary")">
                                @(assessment.IsActive ? "Active" : "Inactive")
                            </span>
                        </div>
                        <div class="card-body">
                            <p class="card-text">@(string.IsNullOrEmpty(assessment.Description) ? "No description provided" : assessment.Description)</p>
                            <p class="text-muted small">
                                <strong>Type:</strong> @assessment.Type<br>
                                <strong>Created:</strong> @assessment.CreatedAt.ToString("MMM dd, yyyy")
                            </p>
                        </div>
                        <div class="card-footer">
                            <div class="btn-group w-100" role="group">
                                <button class="btn btn-outline-primary" @onclick="() => ViewAssessment(assessment.Id)">
                                    <i class="fas fa-eye"></i> View
                                </button>
                                <button class="btn btn-outline-secondary" @onclick="() => EditAssessment(assessment.Id)">
                                    <i class="fas fa-edit"></i> Edit
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!assessments.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-clipboard-list fa-3x text-muted mb-3"></i>
                <h4 class="text-muted">No Assessments Found</h4>
                <p class="text-muted">Create your first assessment to get started.</p>
                <button class="btn btn-primary" @onclick="ShowCreateModal">
                    <i class="fas fa-plus"></i> Create Assessment
                </button>
            </div>
        }
    }
</div>

@* Create Assessment Modal *@
<div class="modal fade @(showCreateModal ? "show d-block" : "")" tabindex="-1" style="@(showCreateModal ? "background-color: rgba(0,0,0,0.5);" : "")">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create New Assessment</h5>
                <button type="button" class="btn-close" @onclick="HideCreateModal"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="createAssessmentDTO" OnValidSubmit="CreateAssessment">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    
                    <div class="mb-3">
                        <label class="form-label">Name *</label>
                        <InputText class="form-control" @bind-Value="createAssessmentDTO.Name" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <InputTextArea class="form-control" rows="3" @bind-Value="createAssessmentDTO.Description" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Type *</label>
                        <InputSelect class="form-select" @bind-Value="createAssessmentDTO.Type">
                            <option value="">Select type...</option>
                            <option value="ASSIST">ASSIST</option>
                            <option value="CRAFFT">CRAFFT</option>
                            <option value="Custom">Custom</option>
                        </InputSelect>
                    </div>
                    
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="HideCreateModal">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@isCreating">
                            @if (isCreating)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Create Assessment
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private List<AssessmentDTO> assessments = new();
    private bool isLoading = true;
    private bool showCreateModal = false;
    private bool isCreating = false;
    private AssessmentDTO createAssessmentDTO = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAssessments();
    }

    private async Task LoadAssessments()
    {
        isLoading = true;
        try
        {
            assessments = await AssessmentService.GetAssessmentsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading assessments: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowCreateModal()
    {
        createAssessmentDTO = new AssessmentDTO();
        showCreateModal = true;
    }

    private void HideCreateModal()
    {
        showCreateModal = false;
    }

    private async Task CreateAssessment()
    {
        isCreating = true;
        try
        {
            await AssessmentService.CreateAssessmentAsync(createAssessmentDTO);
            await LoadAssessments();
            HideCreateModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating assessment: {ex.Message}");
        }
        finally
        {
            isCreating = false;
        }
    }

    private void ViewAssessment(int id)
    {
        try
        {
            Navigation.NavigateTo($"/Management/Assessment/{id}", forceLoad: true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Navigation error: {ex.Message}");
        }
    }

    private void EditAssessment(int id)
    {
        try
        {
            Navigation.NavigateTo($"/Management/Assessment/{id}/edit", forceLoad: true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Navigation error: {ex.Message}");
        }
    }
}