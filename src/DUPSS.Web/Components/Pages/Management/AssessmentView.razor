@page "/Management/Assessment/{id:int}"
@using DUPSS.API.Models.DTOs
@using DUPSS.Web.Components.Layout
@using DUPSS.Web.Components.Service

@inject AssessmentApiService AssessmentApiService
@inject NavigationManager Navigation
@layout ManagementLayout

<PageTitle>Assessment Details</PageTitle>

<div class="container-fluid py-4">
    @if (isLoading)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (assessment == null)
    {
        <div class="alert alert-danger">
            <h4>Assessment Not Found</h4>
            <p>The requested assessment could not be found.</p>
            <button class="btn btn-primary" @onclick="NavigateBack">
                <i class="fas fa-arrow-left"></i> Back to Assessments
            </button>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2>@assessment.Name</h2>
                <span class="badge @(assessment.IsActive ? "bg-success" : "bg-secondary") me-2">
                    @(assessment.IsActive ? "Active" : "Inactive")
                </span>
                <span class="badge bg-info">@assessment.Type</span>
            </div>
            <div>
                <button class="btn btn-outline-primary me-2" @onclick="NavigateBack">
                    <i class="fas fa-arrow-left"></i> Back
                </button>
                <button class="btn btn-primary" @onclick="NavigateToEdit">
                    <i class="fas fa-edit"></i> Edit
                </button>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5><i class="fas fa-info-circle"></i> Assessment Details</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-3">Name:</dt>
                            <dd class="col-sm-9">@assessment.Name</dd>
                            
                            <dt class="col-sm-3">Description:</dt>
                            <dd class="col-sm-9">@(string.IsNullOrEmpty(assessment.Description) ? "No description provided" : assessment.Description)</dd>
                            
                            <dt class="col-sm-3">Type:</dt>
                            <dd class="col-sm-9">@assessment.Type</dd>
                            
                            <dt class="col-sm-3">Status:</dt>
                            <dd class="col-sm-9">
                                <span class="badge @(assessment.IsActive ? "bg-success" : "bg-secondary")">
                                    @(assessment.IsActive ? "Active" : "Inactive")
                                </span>
                            </dd>
                            
                            <dt class="col-sm-3">Created:</dt>
                            <dd class="col-sm-9">@assessment.CreatedAt.ToString("MMMM dd, yyyy 'at' hh:mm tt")</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-cog"></i> Actions</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button class="btn btn-primary" @onclick="NavigateToEdit">
                                <i class="fas fa-edit"></i> Edit Assessment
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    
    private AssessmentDTO? assessment;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAssessment();
    }

    private async Task LoadAssessment()
    {
        isLoading = true;
        try
        {
            assessment = await AssessmentApiService.GetAssessmentAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading assessment: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/Management/Assessment", forceLoad: true);
    }

    private void NavigateToEdit()
    {
        Navigation.NavigateTo($"/Management/Assessment/{Id}/edit", forceLoad: true);
    }
}