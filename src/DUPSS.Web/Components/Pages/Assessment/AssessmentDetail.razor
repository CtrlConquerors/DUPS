@page "/Assessment/Info/{AssessmentId:int}"
@using DUPSS.Web.Components.Service
@using DUPSS.API.Models.DTOs
@inject AssessmentApiService AssessmentService
@inject NavigationManager Navigation

<PageTitle>Assessment Details</PageTitle>

<div class="container-fluid py-4">
    @if (isLoading)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (assessment == null)
    {
        <div class="alert alert-danger">
            <h4>Assessment Not Found</h4>
            <p>The requested assessment could not be found.</p>
            <button class="btn btn-primary" @onclick="NavigateToAssessmentList">
                Back to Assessments
            </button>
        </div>
    }
    else
    {
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/Assessments">Assessments</a></li>
                <li class="breadcrumb-item active">@assessment.Name</li>
            </ol>
        </nav>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2>@assessment.Name</h2>
                <p class="text-muted">@(string.IsNullOrEmpty(assessment.Description) ? "No description provided" : assessment.Description)</p>
            </div>
            <div>
                <button class="btn btn-success me-2" @onclick="ShowCreateVersionModal">
                    <i class="fas fa-plus"></i> Add Version
                </button>
                <button class="btn btn-primary" @onclick="() => NavigateToEditAssessment(paraAssessmentId)">
                    <i class="fas fa-edit"></i> Edit Assessment
                </button>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5>Assessment Info</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Type:</dt>
                            <dd class="col-sm-8">@assessment.Type</dd>
                            <dt class="col-sm-4">Status:</dt>
                            <dd class="col-sm-8">
                                <span class="badge @(assessment.IsActive ? "bg-success" : "bg-secondary")">
                                    @(assessment.IsActive ? "Active" : "Inactive")
                                </span>
                            </dd>
                            <dt class="col-sm-4">Created:</dt>
                            <dd class="col-sm-8">@assessment.CreatedAt.ToString("MMM dd, yyyy")</dd>
                            <dt class="col-sm-4">Versions:</dt>
                            <dd class="col-sm-8">@versions.Count</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h5>Versions</h5>
                    </div>
                    <div class="card-body">
                        @if (versions.Any())
                        {
                            @foreach (var version in versions)
                            {
                                <div class="border rounded p-3 mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="mb-0">Version: @version.Version</h6>
                                        <div>
                                            <span class="badge @(version.IsActive ? "bg-success" : "bg-secondary") me-2">
                                                @(version.IsActive ? "Active" : "Inactive")
                                            </span>
                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => ShowCreateLanguageModal(version.Id)">
                                                <i class="fas fa-plus"></i> Add Language
                                            </button>
                                        </div>
                                    </div>
                                    <p class="text-muted small">
                                        Created: @version.CreatedAt.ToString("MMM dd, yyyy")
                                    </p>

                                    @if (languagesByVersion.ContainsKey(version.Id) && languagesByVersion[version.Id].Any())
                                    {
                                        <div class="row">
                                            @foreach (var language in languagesByVersion[version.Id])
                                            {
                                                <div class="col-md-6 mb-2">
                                                    <div class="card card-body py-2">
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            <div>
                                                                <strong>@language.LanguageName</strong>
                                                                <span class="text-muted">(@language.LanguageCode)</span>
                                                            </div>
                                                            <div>
                                                                <button class="btn btn-sm btn-outline-success"
                                                                        @onclick="() => NavigateToTakeAssessment(paraAssessmentId, language.Id)">
                                                                    <i class="fas fa-play"></i> Take
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="text-muted">No languages configured for this version.</p>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted">No versions created yet.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* Create Version Modal *@
<div class="modal fade @(showCreateVersionModal ? "show d-block" : "")" tabindex="-1"
     style="@(showCreateVersionModal ? "background-color: rgba(0, 0, 0, 0.5)" : "")">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create New Version</h5>
                <button type="button" class="btn-close" @onclick="HideCreateVersionModal"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="createVersionDTO" OnValidSubmit="CreateVersion">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Version *</label>
                        <InputText class="form-control" @bind-Value="createVersionDTO.Version"
                                   placeholder="e.g., 1.0, 2.1, etc." />
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="HideCreateVersionModal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-primary" disabled="@isCreatingVersion">
                            @if (isCreatingVersion)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Create Version
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@* Create Language Modal *@
<div class="modal fade @(showCreateLanguageModal ? "show d-block" : "")" tabindex="-1"
     style="@(showCreateLanguageModal ? "background-color: rgba(0, 0, 0, 0.5)" : "")">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Language</h5>
                <button type="button" class="btn-close" @onclick="HideCreateLanguageModal"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="createLanguageDTO" OnValidSubmit="CreateLanguage">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Language Code *</label>
                        <InputSelect class="form-select" @bind-Value="createLanguageDTO.LanguageCode">
                            <option value="">Select language...</option>
                            <option value="en">English (en)</option>
                            <option value="es">Spanish (es)</option>
                            <option value="fr">French (fr)</option>
                            <option value="de">German (de)</option>
                            <option value="it">Italian (it)</option>
                            <option value="pt">Portuguese (pt)</option>
                            <option value="ru">Russian (ru)</option>
                            <option value="zh">Chinese (zh)</option>
                            <option value="ja">Japanese (ja)</option>
                            <option value="ko">Korean (ko)</option>
                            <option value="ar">Arabic (ar)</option>
                            <option value="hi">Hindi (hi)</option>
                        </InputSelect>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Language Name *</label>
                        <InputText class="form-control" @bind-Value="createLanguageDTO.LanguageName" />
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="HideCreateLanguageModal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-primary" disabled="@isCreatingLanguage">
                            @if (isCreatingLanguage)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Add Language
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int paraAssessmentId { get; set; }

    private AssessmentDTO? assessment;
    private List<AssessmentVersionDTO> versions = new();
    private Dictionary<int, List<AssessmentLanguageDTO>> languagesByVersion = new();
    private bool isLoading = true;
    private bool showCreateVersionModal = false;
    private bool showCreateLanguageModal = false;
    private bool isCreatingVersion = false;
    private bool isCreatingLanguage = false;

    private AssessmentVersionDTO createVersionDTO = new();
    private AssessmentLanguageDTO createLanguageDTO = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAssessment();
    }

    private async Task LoadAssessment()
    {
        isLoading = true;
        try
        {
            assessment = await AssessmentService.GetAssessmentAsync(paraAssessmentId);
            if (assessment != null)
            {
                // Fetch versions separately
                versions = new List<AssessmentVersionDTO>();
                // Note: Since we don't have a direct endpoint to get all versions for an assessment,
                // we'll need to fetch each version individually or modify the API to support this.
                // For now, we'll assume versions are fetched via a hypothetical endpoint or manually.
                // This is a limitation due to the DTO structure change.
                // Here, we'll simulate fetching versions (in a real app, you'd need an API endpoint).
                var allVersions = await Task.WhenAll(
                    (await AssessmentService.GetAssessmentsAsync())
                        .Where(a => a.Id == paraAssessmentId)
                        .SelectMany(a => new[] { 1, 2, 3 }) // Placeholder for version IDs
                        .Select(id => AssessmentService.GetVersionAsync(id))
                );
                versions = allVersions.Where(v => v != null).ToList()!;

                // Fetch languages for each version
                foreach (var version in versions)
                {
                    var languages = new List<AssessmentLanguageDTO>();
                    // Similarly, fetch languages for each version (hypothetical endpoint needed)
                    var language = await AssessmentService.GetAssessmentLanguageAsync(version.Id);
                    if (language != null)
                    {
                        languages.Add(language);
                    }
                    languagesByVersion[version.Id] = languages;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading assessment: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowCreateVersionModal()
    {
        createVersionDTO = new AssessmentVersionDTO { AssessmentId = paraAssessmentId };
        showCreateVersionModal = true;
    }

    private void HideCreateVersionModal()
    {
        showCreateVersionModal = false;
    }

    private void ShowCreateLanguageModal(int versionId)
    {
        createLanguageDTO = new AssessmentLanguageDTO { VersionId = versionId };
        showCreateLanguageModal = true;
    }

    private void HideCreateLanguageModal()
    {
        showCreateLanguageModal = false;
    }

    private async Task CreateVersion()
    {
        isCreatingVersion = true;
        try
        {
            await AssessmentService.CreateVersionAsync(createVersionDTO);
            await LoadAssessment();
            HideCreateVersionModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating version: {ex.Message}");
        }
        finally
        {
            isCreatingVersion = false;
        }
    }

    private async Task CreateLanguage()
    {
        isCreatingLanguage = true;
        try
        {
            await AssessmentService.CreateLanguageAsync(createLanguageDTO);
            await LoadAssessment();
            HideCreateLanguageModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating language: {ex.Message}");
        }
        finally
        {
            isCreatingLanguage = false;
        }
    }
    
    private void NavigateToAssessmentList()
    {
        Navigation.NavigateTo("/Assessments", forceLoad: true);
    }

    private void NavigateToEditAssessment(int AssessmentId)
    {
        Navigation.NavigateTo($"/Management/Assessment/{AssessmentId}/edit", forceLoad: true);
    }
    
    private void NavigateToTakeAssessment(int AssessmentId,int languageId)
    {
        Navigation.NavigateTo($"/Assessment/Take/{AssessmentId}/{languageId}", forceLoad: true);
    }
}