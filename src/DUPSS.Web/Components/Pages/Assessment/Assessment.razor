@page "/Assessment"
@using DUPSS.Web.Components.Service
@using DUPSS.API.Models.DTOs
@inject NavigationManager NavigationManager
@inject AssessmentApiService AssessmentApiService
@inject IJSRuntime JSRuntime

<div class="assessment-page-container">
    <h1 class="page-title">Mental Health & Substance Use Assessments</h1>
    <p class="page-description">
        Complete validated screening tools to assess your mental health and substance use patterns.
        These assessments provide insights and recommendations for your wellbeing.
    </p>

    @if (displayAssessments == null && !hasError)
    {
        <div class="loading-indicator">
            <p>Loading assessments...</p>
            <div class="spinner"></div>
        </div>
    }
    else if (hasError)
    {
        <div class="error-message">
            <p>Oops! Something went wrong while loading assessments. Please try again later.</p>
            <button class="retry-button" @onclick="RetryLoadAssessments">Retry</button>
        </div>
    }
    else if (!displayAssessments.Any())
    {
        <div class="no-assessment-message">
            <p>No assessments available at the moment. Please check back later!</p>
        </div>
    }
    else
    {
        <div class="assessment-grid">
            @foreach (var item in showAllAssessments ? displayAssessments : displayAssessments.Take(DefaultAssessmentDisplayLimit))
            {
                <div class="assessment-card">
                    <div class="card-header">
                        <h3 class="assessment-type">@item.AssessmentType</h3>
                        <span class="assessment-version">@item.Version</span>
                    </div>
                    <div class="card-content">
                        <p class="assessment-description">
                            @(item.Description.Length > 150
                                ? item.Description.Substring(0, 150) + "..."
                                : item.Description)
                        </p>
                        <div class="card-meta">
                            <span class="language-tag">@GetLanguageDisplay(item.Language)</span>
                            <span class="assessment-duration">@GetEstimatedDuration(item.AssessmentType)</span>
                        </div>
                    </div>
                    <div class="card-actions">
                        <button class="btn-primary take-assessment" @onclick="() => StartAssessment(item.AssessmentId, item.AssessmentLanguageId)">
                            <i class="icon-play"></i>
                            Take Assessment
                        </button>
                        <button class="btn-secondary learn-more" @onclick="() => ViewAssessmentInfo(item.AssessmentLanguageId)">
                            <i class="icon-info"></i>
                            Learn More
                        </button>
                    </div>
                </div>
            }
        </div>

        @if (displayAssessments.Count > DefaultAssessmentDisplayLimit && !showAllAssessments)
        {
            <div class="main-explore-button-container">
                <button class="main-explore-button" @onclick="ToggleShowAllAssessments" disabled="@(!_isHydrated)">
                    @(_isHydrated ? "Show More Assessments" : "Loading...")
                </button>
            </div>
        }

        @if (showAllAssessments)
        {
            <div class="main-explore-button-container">
                <button class="main-explore-button" @onclick="ToggleShowAllAssessments">Show Less</button>
            </div>
        }
    }

    <div class="assessment-info-section">
        <h2>About These Assessments</h2>
        <div class="info-grid">
            <div class="info-card">
                <h3>CRAFFT Screening</h3>
                <p>A validated tool for screening adolescents and young adults for substance use disorders. Takes about 2-3 minutes.</p>
            </div>
            <div class="info-card">
                <h3>ASSIST Screening</h3>
                <p>WHO's Alcohol, Smoking and Substance Involvement Screening Test. Comprehensive assessment taking 5-10 minutes.</p>
            </div>
            <div class="info-card">
                <h3>Privacy & Confidentiality</h3>
                <p>Your responses are confidential and used only to provide personalized recommendations for your wellbeing.</p>
            </div>
        </div>
    </div>
</div>

<Footer />

@code {
    private class DisplayAssessment
    {
        public int AssessmentId { get; set; }
        public int AssessmentLanguageId { get; set; }
        public string AssessmentType { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Version { get; set; } = string.Empty;
        public string Language { get; set; } = string.Empty;
    }

    private List<DisplayAssessment>? displayAssessments;
    private bool hasError = false;
    private bool showAllAssessments = false;
    private const int DefaultAssessmentDisplayLimit = 6;
    private bool _isHydrated = false;
    private string? _loadErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAndPrepareAssessmentsAsync();
    }

    private async Task LoadAndPrepareAssessmentsAsync()
    {
        hasError = false;
        _loadErrorMessage = null;
        displayAssessments = null; // Show loading indicator
        StateHasChanged();

        try
        {
            // Fetch all active assessments
            var rawAssessments = await AssessmentApiService.GetAssessmentsAsync();
            var flattenedList = new List<DisplayAssessment>();

            if (rawAssessments != null)
            {
                foreach (var assessment in rawAssessments.Where(a => a.IsActive))
                {
                    // Fetch versions for the assessment
                    var versions = await AssessmentApiService.GetAssessmentVersionsAsync(assessment.Id);
                    foreach (var version in versions.Where(v => v.IsActive))
                    {
                        // Fetch languages for the version
                        var languages = await AssessmentApiService.GetLanguagesForVersionAsync(version.Id);
                        foreach (var language in languages)
                        {
                            flattenedList.Add(new DisplayAssessment
                            {
                                AssessmentId = assessment.Id,
                                AssessmentLanguageId = language.Id,
                                AssessmentType = assessment.Type,
                                Description = assessment.Description ?? GetDefaultDescription(assessment.Type),
                                Version = version.Version,
                                Language = language.LanguageCode
                            });
                        }
                    }
                }
                displayAssessments = flattenedList;
            }
            else
            {
                displayAssessments = new List<DisplayAssessment>();
            }
        }
        catch (Exception ex)
        {
            _loadErrorMessage = $"Error loading assessments: {ex.Message}";
            hasError = true;
        }
        finally
        {
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isHydrated = true;
            if (_loadErrorMessage != null)
            {
                await JSRuntime.InvokeVoidAsync("console.error", _loadErrorMessage);
            }
            else if (displayAssessments != null)
            {
                await JSRuntime.InvokeVoidAsync("console.log", $"Successfully loaded {displayAssessments.Count} assessment languages for display.");
            }
            StateHasChanged();
        }
    }

    private async Task RetryLoadAssessments()
    {
        await LoadAndPrepareAssessmentsAsync();
    }

    private async Task ToggleShowAllAssessments()
    {
        showAllAssessments = !showAllAssessments;
        if (!showAllAssessments)
        {
            await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
        }
    }

    private void StartAssessment(int AssessmentId, int LanguageId)
    {
        NavigationManager.NavigateTo($"/Assessment/Take/{AssessmentId}/{LanguageId}", forceLoad: true);
    }

    private void ViewAssessmentInfo(int AssessmentId)
    {
        NavigationManager.NavigateTo($"/Assessment/Info/{AssessmentId}", forceLoad: true);
    }

    private string GetDefaultDescription(string assessmentType)
    {
        return assessmentType switch
        {
            "CRAFFT" => "A brief screening tool to identify adolescents and young adults who may have a substance use disorder or are at risk of developing one.",
            "ASSIST" => "The World Health Organization's comprehensive screening tool for alcohol, tobacco, and other substance use problems.",
            _ => "A validated screening tool to assess mental health and substance use patterns."
        };
    }

    private string GetLanguageDisplay(string languageCode)
    {
        return languageCode switch
        {
            "eng" => "English",
            "vie" => "Tiếng Việt",
            _ => languageCode.ToUpper()
        };
    }

    private string GetEstimatedDuration(string assessmentType)
    {
        return assessmentType switch
        {
            "CRAFFT" => "2-3 min",
            "ASSIST" => "5-10 min",
            _ => "3-5 min"
        };
    }
}