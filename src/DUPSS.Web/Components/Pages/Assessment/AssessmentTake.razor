@page "/Assessment/Take/{AssessmentId:int}/{LanguageId:int}"
@using DUPSS.API.Models.DTOs
@using DUPSS.Web.Components.Service

@inject AssessmentApiService AssessmentService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Take Assessment</PageTitle>

<div class="container-fluid py-4">
    @if (isLoading)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (assessmentData == null)
    {
        <div class="alert alert-danger">
            <h4>Assessment Not Found</h4>
            <p>@(_loadErrorMessage ?? "The requested assessment could not be found.")</p>
            <button class="btn btn-primary" @onclick="NavigateToHome">
                Return to Home
            </button>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h3 class="card-title mb-0">
                            @assessmentData.Name
                            <span class="badge bg-light text-dark ms-2">@assessmentData.LanguageName</span>
                        </h3>
                        @if (!string.IsNullOrEmpty(assessmentData.Description))
                        {
                            <p class="card-text mt-2 mb-0">@assessmentData.Description</p>
                        }
                    </div>
                    <div class="card-body">
                        @if (!isSubmitted)
                        {
                            <div class="progress mb-4">
                                <div class="progress-bar" role="progressbar" 
                                     style="width: @(progressPercentage)%" 
                                     aria-valuenow="@progressPercentage" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100">
                                    Question @(currentQuestionIndex + 1) of @assessmentData.Questions.Count
                                </div>
                            </div>

                            @if (currentQuestionIndex < assessmentData.Questions.Count)
                            {
                                var question = assessmentData.Questions[currentQuestionIndex];
                                <div class="question-container">
                                    <h4 class="question-text mb-3">
                                        @((currentQuestionIndex + 1)). @question.Text
                                        @if (question.IsRequired)
                                        {
                                            <span class="text-danger">*</span>
                                        }
                                    </h4>

                                    @if (question.Type == "YesNo" || question.Type == "MultipleChoice")
                                    {
                                        <div class="d-grid gap-2">
                                            @foreach (var option in question.Options.OrderBy(o => o.OrderIndex))
                                            {
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" 
                                                           name="question_@question.Id" 
                                                           id="option_@option.Id"
                                                           checked="@IsOptionSelected(question.Id, option.Id)"
                                                           @onchange="() => SelectOption(question.Id, option.Id, option.Value)">
                                                    <label class="form-check-label" for="option_@option.Id">
                                                        @option.Text
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else if (question.Type == "Scale")
                                    {
                                        <div class="row">
                                            @foreach (var option in question.Options.OrderBy(o => o.OrderIndex))
                                            {
                                                <div class="col">
                                                    <div class="text-center">
                                                        <button type="button" 
                                                                class="btn @(GetSelectedOptionClass(question.Id, option.Id)) btn-circle mb-2"
                                                                @onclick="() => SelectOption(question.Id, option.Id, option.Value)">
                                                            @option.Value
                                                        </button>
                                                        <div class="small">@option.Text</div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else if (question.Type == "Text")
                                    {
                                        <textarea class="form-control" rows="3" 
                                                  @bind="textResponses[question.Id]" 
                                                  @bind:event="oninput"
                                                  placeholder="Enter your response here..."></textarea>
                                    }

                                    @if (validationErrors.ContainsKey(question.Id))
                                    {
                                        <div class="text-danger mt-2">
                                            @validationErrors[question.Id]
                                        </div>
                                    }
                                </div>

                                <div class="d-flex justify-content-between mt-4">
                                    <button class="btn btn-outline-secondary" 
                                            @onclick="PreviousQuestion" 
                                            disabled="@(currentQuestionIndex == 0)">
                                        <i class="fas fa-chevron-left"></i> Previous
                                    </button>
                                    
                                    @if (currentQuestionIndex == assessmentData.Questions.Count - 1)
                                    {
                                        <button class="btn btn-success" @onclick="SubmitAssessment" disabled="@isSubmitting">
                                            @if (isSubmitting)
                                            {
                                                <span class="spinner-border spinner-border-sm me-2"></span>
                                            }
                                            Submit Assessment
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-primary" @onclick="NextQuestion">
                                            Next <i class="fas fa-chevron-right"></i>
                                        </button>
                                    }
                                </div>
                            }
                            else if (assessmentData.Questions.Count == 0)
                            {
                                <div class="alert alert-warning">
                                    <p>No questions available for this assessment.</p>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center">
                                <div class="alert alert-success">
                                    <h4><i class="fas fa-check-circle"></i> Assessment Completed!</h4>
                                    <p>Thank you for completing the assessment.</p>
                                    @if (assessmentResult != null)
                                    {
                                        <div class="mt-3">
                                            <h5>Results:</h5>
                                            <p><strong>Total Score:</strong> @assessmentResult.TotalScore</p>
                                            @if (!string.IsNullOrEmpty(assessmentResult.RiskLevel))
                                            {
                                                <p><strong>Risk Level:</strong> 
                                                    <span class="badge @GetRiskLevelClass(assessmentResult.RiskLevel)">
                                                        @assessmentResult.RiskLevel
                                                    </span>
                                                </p>
                                            }
                                        </div>
                                    }
                                </div>
                                <button class="btn btn-primary" @onclick="NavigateToHome">
                                    Return to Home
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .btn-circle {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        font-weight: bold;
    }
    
    .question-container {
        min-height: 300px;
    }
    
    .question-text {
        font-weight: 600;
        color: #2c3e50;
    }
    
    .form-check-label {
        font-weight: 500;
        cursor: pointer;
    }
    
    .progress {
        height: 8px;
    }
</style>

@code {
    [Parameter] public int LanguageId { get; set; }
    [Parameter] public int AssessmentId { get; set; }
    
    private AssessmentForTakingDTO? assessmentData;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool isSubmitted = false;
    private int currentQuestionIndex = 0;
    private AssessmentResponseDTO? assessmentResult;
    private string? _submitErrorMessage;
    
    private Dictionary<int, int> selectedOptions = new();
    private Dictionary<int, string> textResponses = new();
    private Dictionary<int, string> validationErrors = new();
    
    private double progressPercentage => assessmentData?.Questions.Count > 0 
        ? (double)(currentQuestionIndex + 1) / assessmentData.Questions.Count * 100 
        : 0;

    private class OptionDTO
    {
        public int Id { get; set; }
        public string Text { get; set; } = string.Empty;
        public int Value { get; set; }
        public int OrderIndex { get; set; }
    }

    private class AssessmentForTakingDTO
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string Version { get; set; } = string.Empty;
        public string LanguageCode { get; set; } = string.Empty;
        public string LanguageName { get; set; } = string.Empty;
        public List<QuestionDTO> Questions { get; set; } = new();
    }

    private class QuestionDTO
    {
        public int Id { get; set; }
        public int LanguageId { get; set; }
        public string Text { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public bool IsRequired { get; set; }
        public int OrderIndex { get; set; }
        public List<OptionDTO> Options { get; set; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var language = await AssessmentService.GetAssessmentForTakingAsync(LanguageId);
            if (language != null)
            {
                // Fetch assessment details to get Name, Description, Type
                var assessment = await AssessmentService.GetAssessmentAsync(AssessmentId);
                assessmentData = new AssessmentForTakingDTO
                {
                    Id = language.Id,
                    Name = language.Name,
                    Description = language.Description,
                    Type = language.Type,
                    Version = language.Version,
                    LanguageCode = language.LanguageCode,
                    LanguageName = language.LanguageName,
                    Questions = language.Questions.Select(q => new QuestionDTO
                    {
                        Id = q.Id,
                        LanguageId = language.Id,
                        Text = q.Text,
                        Type = q.Type,
                        IsRequired = q.IsRequired,
                        OrderIndex = q.OrderIndex,
                        Options = q.Options.Select(o => new OptionDTO
                        {
                            Id = o.Id,
                            Text = o.Text,
                            Value = o.Value,
                            OrderIndex = o.OrderIndex
                        }).ToList()
                    }).OrderBy(q => q.OrderIndex).ToList()
                };
            }

            // Initialize text responses dictionary
            if (assessmentData?.Questions != null)
            {
                foreach (var question in assessmentData.Questions)
                {
                    if (question.Type == "Text")
                    {
                        textResponses[question.Id] = string.Empty;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _loadErrorMessage = $"Error loading assessment: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string? _loadErrorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _loadErrorMessage != null)
        {
            await JSRuntime.InvokeVoidAsync("console.error", _loadErrorMessage);
        }
        if (_submitErrorMessage != null)
        {
            await JSRuntime.InvokeVoidAsync("alert", _submitErrorMessage);
            _submitErrorMessage = null; // Clear after displaying
        }
    }

    private void SelectOption(int questionId, int optionId, int value)
    {
        selectedOptions[questionId] = optionId;
        validationErrors.Remove(questionId);
        StateHasChanged();
    }

    private bool IsOptionSelected(int questionId, int optionId)
    {
        return selectedOptions.ContainsKey(questionId) && selectedOptions[questionId] == optionId;
    }

    private string GetSelectedOptionClass(int questionId, int optionId)
    {
        return IsOptionSelected(questionId, optionId) ? "btn-primary" : "btn-outline-primary";
    }

    private void NextQuestion()
    {
        if (ValidateCurrentQuestion())
        {
            currentQuestionIndex++;
        }
    }

    private void PreviousQuestion()
    {
        if (currentQuestionIndex > 0)
        {
            currentQuestionIndex--;
            validationErrors.Clear();
        }
    }

    private bool ValidateCurrentQuestion()
    {
        if (assessmentData?.Questions == null || currentQuestionIndex >= assessmentData.Questions.Count)
            return false;

        var question = assessmentData.Questions[currentQuestionIndex];
        validationErrors.Remove(question.Id);

        if (question.IsRequired)
        {
            if (question.Type == "Text")
            {
                if (!textResponses.ContainsKey(question.Id) || string.IsNullOrWhiteSpace(textResponses[question.Id]))
                {
                    validationErrors[question.Id] = "This question is required.";
                    return false;
                }
            }
            else
            {
                if (!selectedOptions.ContainsKey(question.Id))
                {
                    validationErrors[question.Id] = "Please select an answer.";
                    return false;
                }
            }
        }

        return true;
    }

    private async Task SubmitAssessment()
    {
        if (!ValidateCurrentQuestion())
            return;

        isSubmitting = true;
        try
        {
            var responses = new List<QuestionResponseDTO>();
            
            foreach (var question in assessmentData!.Questions)
            {
                var response = new QuestionResponseDTO { QuestionId = question.Id };
                
                if (question.Type == "Text")
                {
                    if (textResponses.ContainsKey(question.Id) && !string.IsNullOrWhiteSpace(textResponses[question.Id]))
                    {
                        response.TextResponse = textResponses[question.Id];
                    }
                }
                else if (selectedOptions.ContainsKey(question.Id))
                {
                    response.SelectedOptionId = selectedOptions[question.Id];
                    var selectedOption = question.Options.FirstOrDefault(o => o.Id == selectedOptions[question.Id]);
                    if (selectedOption != null)
                    {
                        response.NumericResponse = selectedOption.Value;
                    }
                }
                
                responses.Add(response);
            }

            var submitDTO = new AssessmentResponseDTO
            {
                LanguageId = LanguageId,
                RespondentId = Guid.NewGuid().ToString(),
                StartedAt = DateTime.UtcNow,
                CompletedAt = DateTime.UtcNow,
                IsCompleted = true,
                Responses = responses
            };

            assessmentResult = await AssessmentService.SubmitResponseAsync(submitDTO);
            isSubmitted = true;
        }
        catch (Exception ex)
        {
            _submitErrorMessage = $"Error submitting assessment: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private string GetRiskLevelClass(string riskLevel)
    {
        return riskLevel.ToLower() switch
        {
            "low" => "bg-success",
            "medium" => "bg-warning",
            "high" => "bg-danger",
            _ => "bg-secondary"
        };
    }
    
    private void NavigateToHome()
    {
        Navigation.NavigateTo("/", forceLoad: true);
    }
}